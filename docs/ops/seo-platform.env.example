# Hermes 中文站 V3 SEO 平台密钥示例
# 只保留变量名和占位符；真实值仅放在 /root/.hermes/secrets/hermes-zh-v3.env。

# Google Search Console service account JSON：支持 inline JSON 或本地 JSON 文件路径
# inline JSON 示例（建议单行 JSON，private_key 中的换行使用 \n）
GSC_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"<project-id>","private_key_id":"<private-key-id>","private_key":"<private-key>","client_email":"<service-account-email>","token_uri":"https://oauth2.googleapis.com/token"}
# 文件路径示例（真实文件只放 /root/.hermes/secrets/，不要提交）：
# GSC_SERVICE_ACCOUNT_JSON=/root/.hermes/secrets/gsc-service-account.json

# 可选：仅作为本地 SDK 兼容路径，不作为本站脚本读取 JSON 的主来源
GOOGLE_APPLICATION_CREDENTIALS=/root/.hermes/secrets/hermes-zh-gsc-service-account.json

# Bing Webmaster API
BING_WEBMASTER_API_KEY=<bing-webmaster-api-key>

# Baidu URL Push
BAIDU_PUSH_TOKEN=<baidu-push-token>
BAIDU_PUSH_ENDPOINT=http://data.zz.baidu.com/urls?site=https%3A%2F%2Fhermes-zh.com&token=<baidu-push-token>

# IndexNow
INDEXNOW_KEY=<32-char-lowercase-hex-key>
INDEXNOW_KEY_LOCATION=https://hermes-zh.com/<32-char-lowercase-hex-key>.txt
