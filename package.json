{
  "name": "hermes-zh",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/prepare-build-content.ts && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "submit:baidu": "tsx scripts/submit-baidu-urls.ts",
    "submit:indexnow": "tsx scripts/submit-indexnow-urls.ts",
    "sync:content": "tsx scripts/sync-content.ts",
    "build:manifests": "tsx scripts/build-manifests.ts",
    "build:content": "npm run sync:content && npm run build:manifests",
    "verify:content": "tsx scripts/verify-content.ts",
    "verify:content:freshness": "tsx scripts/verify-content-freshness.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "gray-matter": "^4.0.3",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.15",
    "fast-glob": "^3.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
